# ─── HubSpot (server-side / Vercel env) ──────────────────────────────────────
HUBSPOT_ACCESS_TOKEN=          # Private App token with CRM read/write + schema write scope
HUBSPOT_PORTAL_ID=243744265    # Your Loremex HubSpot portal ID

# ─── Resend email (server-side / Vercel env) ──────────────────────────────────
RESEND_API_KEY=                # Get from resend.com dashboard
RESEND_FROM_EMAIL=ls@loremex.ai
RESEND_FROM_NAME=Loremex Team
RESEND_REPLY_TO=ls@loremex.com

# ─── Analytics (client-side, VITE_ prefix required) ───────────────────────────
VITE_POSTHOG_KEY=              # Get from posthog.com → Project Settings → API Keys
VITE_POSTHOG_HOST=https://us.i.posthog.com

# ─── CTA / Calendly ───────────────────────────────────────────────────────────
VITE_CALENDLY_URL=https://calendly.com/loremex/intro

# ─── App config ───────────────────────────────────────────────────────────────
# Leave blank in production (Vercel serves api/ functions at same origin)
# Set to http://localhost:3001 only if running the Express dev server without Vite proxy
VITE_API_BASE_URL=

VITE_BASE_URL=https://assessment.loremex.ai
PORT=3001
NODE_ENV=development

# ─── Debug (optional) ─────────────────────────────────────────────────────────
HUBSPOT_DEBUG_KEY=             # Set to enable /api/retry-queue-status endpoint
