# HubSpot (server-side)
HUBSPOT_ACCESS_TOKEN=          # Private App token with CRM read/write + schema write scope
HUBSPOT_API_KEY=               # Legacy API key (deprecated; use HUBSPOT_ACCESS_TOKEN)

# Resend (server-side)
RESEND_API_KEY=                # Get from resend.com dashboard
RESEND_FROM_EMAIL=onboarding@resend.dev   # Use Resend's verified sender for testing; swap to your domain in Sprint 5
RESEND_REPLY_TO=hello@loremex.ai

# Posthog analytics (client-side, optional)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# App URLs
VITE_BASE_URL=http://localhost:5173
PORT=3001
NODE_ENV=development
